# Copy to .env.local and fill in the providers you intend to use.
# Any single provider is sufficient — switch between them in the UI.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Anthropic
CLAUDE_API_KEY=
CLAUDE_MODEL=opus-4.7

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# xAI Grok
GROK_API_KEY=
GROK_MODEL=grok-3
GROK_API_BASE=https://api.x.ai/v1

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large
MISTRAL_ENDPOINT=https://api.mistral.ai/v1

# DeepSeek NLU
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_ENDPOINT=https://api.deepseek.com

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_ENDPOINT=https://nvidia.com

# Azure AI Foundry
FOUNDRY_API_KEY=
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL=

# Default provider (openai | anthropic | gemini | foundry | grok)
AGENTDIAGRAM_DEFAULT_PROVIDER=openai

# Optional: override the parent-directory default for repo scanning.
# AGENTDIAGRAM_DEFAULT_REPO_PATH=/absolute/path/to/repo
