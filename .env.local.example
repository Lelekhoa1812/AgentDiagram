# Copy to .env.local and fill in the providers you intend to use.
# Any single provider is sufficient — switch between them in the UI.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Anthropic
CLAUDE_API_KEY=
CLAUDE_MODEL=opus-4.7

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# xAI Grok
GROK_API_KEY=
GROK_MODEL=grok-3
GROK_API_BASE=https://api.x.ai/v1

# Azure AI Foundry
FOUNDRY_API_KEY=
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL=

# Default provider (openai | anthropic | gemini | foundry | grok)
AGENTDIAGRAM_DEFAULT_PROVIDER=openai

# Optional: override the parent-directory default for repo scanning.
# AGENTDIAGRAM_DEFAULT_REPO_PATH=/absolute/path/to/repo
